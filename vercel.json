{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "destination": "https://yupify-reworked.onrender.com/api/$1"
    },
    {
      "src": "/health",
      "destination": "https://yupify-reworked.onrender.com/health"
    },
    {
      "src": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
